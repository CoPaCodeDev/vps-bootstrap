FROM codercom/code-server:latest

USER root

# System-Pakete
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    jq \
    ripgrep \
    python3 \
    python3-pip \
    python3-venv \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Node.js 20 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Playwright Chromium Dependencies
RUN npx playwright install --with-deps chromium

# coder User sudo ohne Passwort
RUN echo "coder ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/coder

# Arbeitsverzeichnisse
RUN mkdir -p /home/coder/projects /home/coder/.claude /shared/videos \
    && chown -R coder:coder /home/coder/projects /home/coder/.claude /shared/videos

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER coder

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
