FROM node:20-bookworm

# System-Packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    openssh-client \
    curl \
    wget \
    jq \
    ripgrep \
    bash \
    sed \
    ffmpeg \
    python3 \
    python3-pip \
    python3-venv \
    # Playwright Chromium Dependencies
    libnss3 \
    libgbm1 \
    libasound2 \
    libatk-bridge2.0-0 \
    libdrm2 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# yq (YAML Parser)
RUN curl -fsSL "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_$(dpkg --print-architecture)" \
    -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Playwright
RUN npm install -g @playwright/test \
    && PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers npx playwright install chromium

# User claude erstellen
RUN groupadd -g 1000 claude && useradd -u 1000 -g 1000 -m -d /home/claude -s /bin/bash claude

# Arbeitsverzeichnisse
RUN mkdir -p /home/claude/projects /home/claude/.claude /home/claude/.npm \
    /home/claude/.cache/ms-playwright /shared/videos \
    && chown -R claude:claude /home/claude /shared/videos

# Playwright-Browser ins persistente Verzeichnis linken
RUN cp -r /opt/pw-browsers/* /home/claude/.cache/ms-playwright/ \
    && chown -R claude:claude /home/claude/.cache/ms-playwright

# API Wrapper
COPY api-wrapper/requirements.txt /opt/api-wrapper/requirements.txt
RUN pip3 install --no-cache-dir --break-system-packages -r /opt/api-wrapper/requirements.txt

COPY api-wrapper/ /opt/api-wrapper/
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER claude
WORKDIR /home/claude

ENV DISABLE_AUTOUPDATER=1
ENV PLAYWRIGHT_BROWSERS_PATH=/home/claude/.cache/ms-playwright

EXPOSE 8000

HEALTHCHECK --interval=10s --timeout=5s --retries=5 \
    CMD curl -f http://localhost:8000/api/health || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
