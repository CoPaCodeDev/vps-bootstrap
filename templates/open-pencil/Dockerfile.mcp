FROM oven/bun:1 AS build

WORKDIR /app

# Package-Manifeste zuerst fuer besseres Layer-Caching
COPY package.json bun.lock ./
COPY packages/core/package.json packages/core/package.json
COPY packages/cli/package.json packages/cli/package.json
COPY packages/mcp/package.json packages/mcp/package.json
COPY packages/acp/package.json packages/acp/package.json
COPY packages/docs/package.json packages/docs/package.json

RUN bun install --frozen-lockfile

COPY . .
RUN cd packages/mcp && bun run build

# --- Produktions-Image ---
FROM oven/bun:1-slim

WORKDIR /app

COPY --from=build /app/packages/mcp/dist ./dist
COPY --from=build /app/packages/mcp/package.json ./package.json
COPY --from=build /app/packages/core ./packages/core
COPY --from=build /app/node_modules ./node_modules

ENV HOST=0.0.0.0
ENV PORT=7600
ENV WS_PORT=7601

EXPOSE 7600 7601

CMD ["bun", "run", "dist/index.js"]
